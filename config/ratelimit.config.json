{
  "_comment": "Edit this file to change limits/algorithm. The server hot-reloads it within ~150ms (or use the admin API). No code changes or restart required.",
  "algorithm": "token-bucket",
  "identification": {
    "header": "x-api-key",
    "ipFallback": true,
    "trustProxy": true
  },
  "defaultTier": "standard",
  "tiers": {
    "standard": {
      "limit": 100,
      "windowMs": 60000
    },
    "premium": {
      "limit": 500,
      "windowMs": 60000
    }
  },
  "clients": {
    "demo-standard-key": "standard",
    "demo-premium-key": "premium"
  },
  "methodClasses": {
    "read": [
      "GET",
      "HEAD",
      "OPTIONS"
    ]
  },
  "methodMultipliers": {
    "read": 1,
    "write": 0.2
  },
  "endpointOverrides": [
    {
      "method": "POST",
      "path": "/api/expensive",
      "limit": 5,
      "windowMs": 60000
    }
  ],
  "skipPaths": [
    "/health"
  ],
  "skipPrefixes": [
    "/admin",
    "/docs",
    "/dashboard",
    "/__ratelimit",
    "/metrics",
    "/favicon"
  ],
  "admin": {
    "token": "admin-secret-token"
  },
  "metrics": {
    "recentEvents": 200
  },
  "store": {
    "sweepIntervalMs": 30000,
    "maxIdleMs": 120000,
    "maxKeys": 100000
  }
}
